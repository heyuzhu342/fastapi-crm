{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "NotebookEdit",
      "Bash",
      "Glob",
      "Grep",
      "TodoWrite",
      "TaskOutput",
      "TaskStop",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Agent",
      "AskUserQuestion",
      "CronCreate",
      "CronDelete",
      "CronList",
      "SendMessage",
      "ScheduleWakeup"
    ],
    "deny": [
      "Bash(rm -rf /:**)",
      "Bash(rm -rf ~:**)",
      "Bash(> /dev/sda:**)",
      "Bash(mkfs:**)",
      "Bash(dd if=:**)",
      "Bash(curl * | sh:**)",
      "Bash(wget * | sh:**)",
      "Bash(:(){ :|:& };:**)"
    ]
  }
}
