# ============================================
# FastAPI CRM 环境变量配置
# 复制为 .env 并修改
# ============================================

# App
APP_NAME=FastAPI CRM
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key
ENVIRONMENT=development

# Database (MySQL 5.7)
DATABASE_URL=mysql+asyncmy://root:password@localhost:3306/fastapi_crm?charset=utf8mb4
DATABASE_URL_SYNC=mysql+pymysql://root:password@localhost:3306/fastapi_crm?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Qiniu Cloud Storage
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET_NAME=
QINIU_DOMAIN=
QINIU_ENABLED=false

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
